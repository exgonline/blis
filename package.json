{
  "name": "blis",
  "version": "2.0.0",
  "description": "Building Load Intelligence Service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "migrate": "ts-node src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "seed": "ts-node src/db/migrate.ts --seed",
    "create-api-key": "ts-node src/scripts/create-api-key.ts",
    "generate-key": "ts-node src/scripts/create-api-key.ts",
    "run-jobs": "ts-node src/scripts/run-jobs-once.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "node-cron": "^3.0.0",
    "pg": "^8.11.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
