# Server
PORT=3001
NODE_ENV=production
API_VERSION=v1
LOG_LEVEL=info

# PostgreSQL — local development
# On Render, set DATABASE_URL instead (linked automatically via "Add from Database")
# DATABASE_URL=postgresql://user:password@host:5432/dbname
PGHOST=localhost
PGPORT=5432
PGDATABASE=blis
PGUSER=blis_user
PGPASSWORD=changeme
PGSSL=false
# Set PGSSL=true on Render

# EPC API — set in Render dashboard, never commit
EPC_API_EMAIL=your-email@example.com
EPC_API_KEY=your-epc-api-key
EPC_API_BASE_URL=https://epc.opendatacommunities.org/api/v1/non-domestic

# Master API key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set in Render dashboard, never commit
BLIS_MASTER_API_KEY=your-master-api-key

# Service Configuration
BLIS_BATCH_SIZE=20
BLIS_EPC_REQUEST_DELAY_MS=200
BLIS_EPC_TIMEOUT_MS=10000
BLIS_DB_RETRY_COUNT=3
BLIS_DB_POOL_MIN=2
BLIS_DB_POOL_MAX=10
